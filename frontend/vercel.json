{
  "git": {
    "deploymentEnabled": {
      "main": true,
    
      "*": false
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?<subdomain>.+).wono.co"
        }
      ],
      "destination": "/?subdomain=:subdomain&path=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}